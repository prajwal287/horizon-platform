# Copy this file to terraform.tfvars to override defaults (optional).
# From project root: cp terraform/terraform.tfvars.example terraform/terraform.tfvars

# Required — real GCP project ID (Console or: gcloud config get-value project). Lowercase only.
# Do not apply with a fake string: bucket name becomes "${project_id}-job-lakehouse-raw" and must be valid DNS.
project_id   = "your-real-gcp-project-id"
# Display-oriented name; spaces become hyphens in GCS/BQ/Pub/Sub labels (GCP forbids spaces there).
project_name = "My data lakehouse"

# Optional: override other defaults
# region     = "us-central1"
# gcs_bucket_name       = "job-lakehouse-raw"
# bigquery_dataset_id   = "job_market_analysis"
# pubsub_topic_name     = "job-stream-input"
# service_account_name  = "lakehouse-sa"
# lifecycle_nearline_days = 90

# Streamlit on Cloud Run (optional). Build/push the image FIRST using URI:
#   ${region}-docker.pkg.dev/${project_id}/horizon-streamlit/dashboard:latest
# (defaults: horizon-streamlit repo, dashboard image). Then:
# enable_streamlit_cloud_run      = true
# streamlit_allow_unauthenticated = true
# streamlit_ingress_all          = true
# streamlit_container_image      = ""  # or set full URI to override defaults
