data/
secrets/
.env
.dlt/

# Local API / editor secrets (never commit)
.streamlit/secrets.toml
kaggle.json
**/application_default_credentials.json

# Python
.venv/
venv/
__pycache__/
*.pyc

# Generated / eval outputs
comparison_skills.csv

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
