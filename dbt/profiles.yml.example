# Copy to ~/.dbt/profiles.yml (or merge the horizon_platform block into your existing file).
#
# Before dbt run: export GOOGLE_CLOUD_PROJECT=<real-id>  (same as Terraform / .env — NOT a placeholder string)
# Optional: export BIGQUERY_DATASET=job_market_analysis if not using the default below.
#
# Auth: method oauth uses Application Default Credentials (gcloud auth application-default login).

horizon_platform:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: oauth
      project: "{{ env_var('GOOGLE_CLOUD_PROJECT') }}"
      dataset: "{{ env_var('BIGQUERY_DATASET', 'job_market_analysis') }}"
      threads: 4
      timeout_seconds: 300
      # Match Terraform google_bigquery_dataset.location (default us-central1)
      location: us-central1
