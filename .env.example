# Copy to `.env` in the repo root (`.env` is gitignored — never commit real values).
# Required: GCP project and GCS bucket — use Terraform outputs or your own IDs.
#   terraform -chdir=terraform output -raw project_id
#   terraform -chdir=terraform output -raw gcs_bucket_name

GOOGLE_CLOUD_PROJECT=YOUR_GCP_PROJECT_ID
GCS_BUCKET=YOUR_GCP_PROJECT_ID-your-bucket-name
# Optional: BigQuery dataset (default: job_market_analysis)
BIGQUERY_DATASET=job_market_analysis

# Kaggle pipelines only — https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
# Use KAGGLE_KEY or KAGGLE_API_TOKEN
KAGGLE_KEY=your_kaggle_api_token
# KAGGLE_API_TOKEN=your_kaggle_api_token

# Optional: taxonomy skills for some sources
EXTRACT_SKILLS_TAXONOMY=1

# Optional — Gemini for skills extraction / ingestion (not the Streamlit dashboard)
# GOOGLE_API_KEY=

# Optional — dbt gold dataset for agents.bq_tools (default: {BIGQUERY_DATASET}_dbt_gold)
# DBT_GOLD_DATASET=your_dataset_dbt_gold
